<Window x:Class="DbSyncTool.Views.Dialogs.TaskConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="任务配置" Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="56"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource AccentBlueBrush}">
            <Grid Margin="16,0">
                <TextBlock x:Name="DialogTitle" Text="新增任务" FontSize="15" FontWeight="SemiBold"
                           Foreground="White" VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right" Background="Transparent"
                        BorderThickness="0" Foreground="White" FontSize="16" Cursor="Hand"
                        Click="Close_Click"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="24,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="任务名称 *" Style="{StaticResource FormLabel}"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtName" Style="{StaticResource InputTextBox}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="任务描述" Style="{StaticResource FormLabel}"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtDesc" Style="{StaticResource InputTextBox}"
                         Height="56" AcceptsReturn="True" TextWrapping="Wrap"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="数据调用配置 *" Style="{StaticResource FormLabel}"/>
                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="CmbDataCall" Style="{StaticResource InputComboBox}"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="触发方式 *" Style="{StaticResource FormLabel}"/>
                <ComboBox Grid.Row="6" Grid.Column="1" x:Name="CmbTrigger" Style="{StaticResource InputComboBox}"
                          SelectionChanged="Trigger_Changed" SelectedIndex="0">
                    <ComboBoxItem Content="一次性执行" Tag="Once"/>
                    <ComboBoxItem Content="按时间间隔循环" Tag="Interval"/>
                    <ComboBoxItem Content="定时触发" Tag="Cron"/>
                </ComboBox>

                <!-- 执行时间 (一次性/定时) -->
                <TextBlock Grid.Row="8" Grid.Column="0" Text="执行时间 *" Style="{StaticResource FormLabel}"
                           x:Name="LblSchedule"/>
                <Grid Grid.Row="8" Grid.Column="1" x:Name="PnlSchedule">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="90"/>
                  </Grid.ColumnDefinitions>
                  <!-- 日期部分 -->
                  <DatePicker Grid.Column="0" x:Name="DpSchedule" Height="32" FontSize="13"
                              SelectedDateChanged="DpSchedule_Changed"/>
                  <!-- 时间部分 HH:mm:ss -->
                  <TextBox Grid.Column="2" x:Name="TxtScheduleTime"
                           Style="{StaticResource InputTextBox}"
                           Text="00:00:00" Height="32" FontSize="13"
                           MaxLength="8"
                           ToolTip="时间格式：HH:mm:ss"
                           PreviewTextInput="TxtTime_PreviewInput"
                           LostFocus="TxtTime_LostFocus"/>
                </Grid>

                <!-- Cron 表达式 -->
                <TextBlock Grid.Row="8" Grid.Column="0" Text="Cron表达式 *" Style="{StaticResource FormLabel}"
                           x:Name="LblCron" Visibility="Collapsed"/>
                <Grid Grid.Row="8" Grid.Column="1" x:Name="PnlCron" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBox Grid.Row="0" x:Name="TxtCron" Style="{StaticResource InputTextBox}"
                             Text="0 0 * * *"
                             ToolTip="5位Cron表达式：分 时 日 月 周&#10;每天0点：0 0 * * *&#10;每天8点：0 8 * * *&#10;每小时：0 * * * *&#10;每30分钟：*/30 * * * *&#10;每天8点和20点：0 8,20 * * *"/>
                    <WrapPanel Grid.Row="2" Orientation="Horizontal">
                        <Button Content="每天0点" Tag="0 0 * * *" FontSize="11" Height="24" Padding="6,0"
                                Style="{StaticResource SecondaryButton}" Margin="0,0,4,0"
                                Click="CronPreset_Click"/>
                        <Button Content="每天8点" Tag="0 8 * * *" FontSize="11" Height="24" Padding="6,0"
                                Style="{StaticResource SecondaryButton}" Margin="0,0,4,0"
                                Click="CronPreset_Click"/>
                        <Button Content="每小时" Tag="0 * * * *" FontSize="11" Height="24" Padding="6,0"
                                Style="{StaticResource SecondaryButton}" Margin="0,0,4,0"
                                Click="CronPreset_Click"/>
                        <Button Content="每30分钟" Tag="*/30 * * * *" FontSize="11" Height="24" Padding="6,0"
                                Style="{StaticResource SecondaryButton}"
                                Click="CronPreset_Click"/>
                    </WrapPanel>
                </Grid>

                <!-- 循环间隔 -->
                <TextBlock Grid.Row="8" Grid.Column="0" Text="间隔设置 *" Style="{StaticResource FormLabel}"
                           x:Name="LblInterval" Visibility="Collapsed"/>
                <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal"
                            x:Name="PnlInterval" Visibility="Collapsed">
                    <TextBox x:Name="TxtInterval" Style="{StaticResource InputTextBox}" Width="80" Text="5"/>
                    <ComboBox x:Name="CmbIntervalUnit" Style="{StaticResource InputComboBox}"
                              Width="100" Margin="8,0,0,0" SelectedIndex="0">
                        <ComboBoxItem Content="分钟"/>
                        <ComboBoxItem Content="小时"/>
                        <ComboBoxItem Content="天"/>
                    </ComboBox>
                </StackPanel>

                <!-- 执行参数 -->
                <TextBlock Grid.Row="10" Grid.Column="0" Text="最大数据量" Style="{StaticResource FormLabel}"/>
                <TextBox Grid.Row="10" Grid.Column="1" x:Name="TxtMaxRows" Style="{StaticResource InputTextBox}" Text="10000"/>

                <TextBlock Grid.Row="12" Grid.Column="0" Text="失败重试次数" Style="{StaticResource FormLabel}"/>
                <TextBox Grid.Row="12" Grid.Column="1" x:Name="TxtRetry" Style="{StaticResource InputTextBox}" Text="3"/>

                <TextBlock Grid.Row="14" Grid.Column="0" Text="并发线程数" Style="{StaticResource FormLabel}"/>
                <TextBox Grid.Row="14" Grid.Column="1" Style="{StaticResource InputTextBox}" Text="1" IsEnabled="False"/>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2" BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="0,1,0,0" Background="White">
            <Grid Margin="24,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" Style="{StaticResource SecondaryButton}" Click="Cancel_Click" Margin="0,0,8,0"/>
                    <Button Content="保存" Style="{StaticResource PrimaryButton}" Click="Save_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
