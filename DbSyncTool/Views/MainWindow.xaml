<Window x:Class="DbSyncTool.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="本地中间库数据同步工具"
        Height="700" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource PageBgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- 顶部导航栏 -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#5B7FA3" Offset="0"/>
                    <GradientStop Color="#8BA4BE" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="本地中间库同步工具" FontSize="16" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center" Margin="16,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <TextBlock x:Name="BreadcrumbText" Text="主页" Foreground="#D0E4F7" FontSize="12"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="28" Height="28" Fill="#4A90D9"/>
                    <TextBlock Text="管理员01" Foreground="White" FontSize="13"
                               VerticalAlignment="Center" Margin="8,0,4,0"/>
                </StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="0" VerticalAlignment="Bottom" Height="1"
                Background="#D0D5DD" Opacity="0.5"/>

        <!-- 主体区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 侧边栏 -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBgBrush}" Panel.ZIndex="10">
                <ListBox x:Name="MenuListBox"
                         Background="Transparent" BorderThickness="0"
                         SelectionChanged="MenuListBox_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource SidebarMenuItemStyle}"/>
                    </ListBox.ItemContainerStyle>

                    <ListBoxItem Tag="DbConfig">
                        <Grid Height="44">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🗄" FontSize="18"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="数据库配置" FontSize="13"
                                       VerticalAlignment="Center" Foreground="#E2E8F0"/>
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Tag="ApiConfig">
                        <Grid Height="44">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="☁" FontSize="18"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="API调用" FontSize="13"
                   VerticalAlignment="Center" Foreground="#E2E8F0"/>
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Tag="Proc">
                        <Grid Height="44">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="⚙" FontSize="18"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="存储过程" FontSize="13"
                                       VerticalAlignment="Center" Foreground="#E2E8F0"/>
                        </Grid>
                    </ListBoxItem>



                    <ListBoxItem Tag="TaskConfig">
                        <Grid Height="44">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="📅" FontSize="18"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="任务配置" FontSize="13"
                                       VerticalAlignment="Center" Foreground="#E2E8F0"/>
                        </Grid>
                    </ListBoxItem>

                    <ListBoxItem Tag="ScheduledSync">
                        <Grid Height="44">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🕐" FontSize="18"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="定时任务同步" FontSize="13"
                                       VerticalAlignment="Center" Foreground="#E2E8F0"/>
                        </Grid>
                    </ListBoxItem>

                    <!--<ListBoxItem Tag="LogView">
                        <Grid Height="44">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="📋" FontSize="18"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="日志查看" FontSize="13"
                                       VerticalAlignment="Center" Foreground="#E2E8F0"/>
                        </Grid>
                    </ListBoxItem>-->
                </ListBox>
            </Border>

            <!-- 主内容区 -->
            <Frame Grid.Column="1" x:Name="MainFrame"
                   NavigationUIVisibility="Hidden"
                   Background="{StaticResource PageBgBrush}"/>
        </Grid>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2" Background="{StaticResource StatusBarBgBrush}"
                BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessGreenBrush}" Margin="0,0,4,0"/>
                    <TextBlock Text="就绪" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>
                <TextBlock Grid.Column="1" x:Name="StatusText"
                           Text="欢迎使用 MES 中间库数据同步工具"
                           FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox x:Name="ChkAutoStart"
                              Content="开机自启" FontSize="12"
                              Foreground="{StaticResource TextMutedBrush}"
                              Margin="0,0,12,0"
                              Checked="ChkAutoStart_Changed"
                              Unchecked="ChkAutoStart_Changed"/>
                    <TextBlock Text="v1.0.0" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
