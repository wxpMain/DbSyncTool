<Page x:Class="DbSyncTool.Views.Pages.LogViewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="日志查看"
      Background="#F0F2F5">

  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- 页标题 -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Text="日志查看" Style="{StaticResource PageTitle}"/>
      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
        <Button Content="📁 打开日志目录" Style="{StaticResource SecondaryButton}"
                Click="BtnOpenDir_Click" Margin="0,0,8,0"/>
        <Button Content="⬇ 导出日志" Style="{StaticResource PrimaryButton}"
                Click="BtnExport_Click"/>
      </StackPanel>
    </Grid>

    <!-- 过滤器卡片 -->
    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="16,14" Margin="0,0,0,16">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="160"/>
          <ColumnDefinition Width="16"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="160"/>
          <ColumnDefinition Width="24"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="130"/>
          <ColumnDefinition Width="24"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="200"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0" Text="开始日期:" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
        <DatePicker Grid.Column="1" x:Name="DpFrom" SelectedDateChanged="Filter_Changed"
                    Style="{StaticResource {x:Type DatePicker}}" Height="34"/>

        <TextBlock Grid.Column="3" Text="结束日期:" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
        <DatePicker Grid.Column="4" x:Name="DpTo" SelectedDateChanged="Filter_Changed"
                    Style="{StaticResource {x:Type DatePicker}}" Height="34"/>

        <TextBlock Grid.Column="6" Text="级别:" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
        <ComboBox Grid.Column="7" x:Name="CbLevel" Style="{StaticResource InputComboBox}"
                  SelectionChanged="Filter_Changed">
          <ComboBoxItem Content="全部" IsSelected="True" Tag=""/>
          <ComboBoxItem Content="DEBUG" Tag="DEBUG"/>
          <ComboBoxItem Content="INFO" Tag="INFO"/>
          <ComboBoxItem Content="WARNING" Tag="WARNING"/>
          <ComboBoxItem Content="ERROR" Tag="ERROR"/>
          <ComboBoxItem Content="FATAL" Tag="FATAL"/>
        </ComboBox>

        <TextBlock Grid.Column="9" Text="关键词:" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
        <TextBox Grid.Column="10" x:Name="TxtKeyword" Style="{StaticResource InputTextBox}"
                 TextChanged="TxtKeyword_TextChanged" Height="34"/>

        <Button Grid.Column="12" Content="清除过滤" Style="{StaticResource SecondaryButton}"
                Click="BtnClearFilter_Click" Padding="12,6"/>
      </Grid>
    </Border>

    <!-- 日志内容卡片 (含Tab) -->
    <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tab 切换 + 统计 -->
        <Border Grid.Row="0" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
          <Grid Margin="16,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Tab 按钮 -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
              <Border x:Name="TabRunBorder" BorderBrush="#3182CE" BorderThickness="0,0,0,2"
                      Margin="0,0,4,0" Padding="16,12">
                <Button x:Name="TabRunBtn" Content="运行日志" BorderThickness="0" Background="Transparent"
                        FontSize="13" FontWeight="Medium" Foreground="#3182CE"
                        Click="TabRun_Click" Cursor="Hand"/>
              </Border>
              <Border x:Name="TabErrBorder" BorderBrush="Transparent" BorderThickness="0,0,0,2"
                      Padding="16,12">
                <Button x:Name="TabErrBtn" Content="错误日志" BorderThickness="0" Background="Transparent"
                        FontSize="13" FontWeight="Medium" Foreground="#718096"
                        Click="TabErr_Click" Cursor="Hand"/>
              </Border>
            </StackPanel>

            <!-- 计数 -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock x:Name="TxtLogCount" Text="共 0 条" FontSize="12"
                         Foreground="#718096" VerticalAlignment="Center" Margin="0,0,12,0"/>
              <Button Content="↺ 刷新" Style="{StaticResource SecondaryButton}"
                      Padding="10,5" FontSize="12" Click="BtnRefresh_Click"/>
            </StackPanel>
          </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="1" x:Name="LogGrid" Style="{StaticResource ModernDataGrid}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionChanged="LogGrid_SelectionChanged">
          <DataGrid.Columns>
            <DataGridTextColumn Header="时间" Binding="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss.fff'}"
                                Width="175" IsReadOnly="True"/>
            <DataGridTemplateColumn Header="级别" Width="80">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <Border CornerRadius="8" Padding="8,2" HorizontalAlignment="Center"
                          Background="{Binding LevelBrush}">
                    <TextBlock Text="{Binding Level}" Foreground="White" FontSize="11" FontWeight="Medium"/>
                  </Border>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="模块" Binding="{Binding Module}" Width="100" IsReadOnly="True"/>
            <DataGridTextColumn Header="消息" Binding="{Binding Message}" Width="*" IsReadOnly="True">
              <DataGridTextColumn.ElementStyle>
                <Style TargetType="TextBlock">
                  <Setter Property="TextWrapping" Value="NoWrap"/>
                  <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                </Style>
              </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>
          </DataGrid.Columns>
        </DataGrid>
      </Grid>
    </Border>

    <!-- 详情面板 -->
    <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,12,0,0" Padding="14,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="详情:" Style="{StaticResource FormLabel}" VerticalAlignment="Top" Margin="0,2,12,0"/>
        <TextBox Grid.Column="1" x:Name="TxtDetail" IsReadOnly="True" TextWrapping="Wrap"
                 BorderThickness="0" Background="Transparent" FontFamily="Consolas" FontSize="12"
                 Foreground="#4A5568" MaxHeight="80" VerticalScrollBarVisibility="Auto"/>
      </Grid>
    </Border>
  </Grid>
</Page>
