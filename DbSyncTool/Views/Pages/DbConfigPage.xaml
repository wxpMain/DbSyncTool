<Page x:Class="DbSyncTool.Views.Pages.DbConfigPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="数据库配置" Background="{StaticResource PageBgBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Style="{StaticResource PageTitle}" Text="数据库配置管理"/>

        <!-- 搜索区 -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="数据库类型：" Style="{StaticResource FormLabel}"/>
                <ComboBox Grid.Column="1" x:Name="SearchDbType" Style="{StaticResource InputComboBox}"
                          SelectedIndex="0">
                    <ComboBoxItem Content="全部"/>
                    <ComboBoxItem Content="SQL Server"/>
                    <ComboBoxItem Content="MySQL"/>
                </ComboBox>

                <TextBlock Grid.Column="2" Text="服务器地址：" Style="{StaticResource FormLabel}" Margin="12,0,8,0"/>
                <TextBox Grid.Column="3" x:Name="SearchServer" Style="{StaticResource InputTextBox}"
                         Text="" Tag="请输入服务器地址"/>

                <TextBlock Grid.Column="4" Text="数据库名：" Style="{StaticResource FormLabel}" Margin="12,0,8,0"/>
                <TextBox Grid.Column="5" x:Name="SearchDbName" Style="{StaticResource InputTextBox}"
                         Text="" Tag="请输入数据库名"/>

                <StackPanel Grid.Column="7" Orientation="Horizontal">
                    <Button Style="{StaticResource PrimaryButton}" Content="🔍 搜索"
                            Click="Search_Click"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="重置"
                            Click="Reset_Click" Margin="8,0,0,0"/>
                </StackPanel>

                <Button Grid.Column="9" Style="{StaticResource PrimaryButton}" Content="＋ 新增配置"
                        Click="AddNew_Click"/>
            </Grid>
        </Border>

        <!-- 数据表格区 -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0" x:Name="ConfigGrid"
                          Style="{StaticResource ModernDataGrid}"
                          Margin="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="配置名称" Binding="{Binding ConfigName}" Width="160"/>
                        <DataGridTextColumn Header="数据库类型" Binding="{Binding DbTypeDisplay}" Width="100"/>
                        <DataGridTextColumn Header="服务器地址" Binding="{Binding ServerAddress}" Width="160"/>
                        <DataGridTextColumn Header="端口" Binding="{Binding Port}" Width="60"/>
                        <DataGridTextColumn Header="数据库名称" Binding="{Binding DatabaseName}" Width="140"/>
                        <DataGridTextColumn Header="账号" Binding="{Binding Account}" Width="100"/>
                        <DataGridTextColumn Header="创建时间" Binding="{Binding CreateTime, StringFormat='yyyy-MM-dd HH:mm'}" Width="140"/>
                        <DataGridTemplateColumn Header="操作" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4,0">
                                        <Button Content="编辑" Style="{StaticResource SecondaryButton}"
                                                Height="26" Padding="10,0" Margin="0,0,6,0"
                                                Click="Edit_Click" Tag="{Binding Id}"/>
                                        <Button Content="删除" Style="{StaticResource DangerButton}"
                                                Height="26" Padding="10,0"
                                                Click="Delete_Click" Tag="{Binding Id}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 分页 -->
                <Border Grid.Row="1" Padding="16,8" BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="TotalCountText" Text="共 0 条"
                                   FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Content="«" Style="{StaticResource SecondaryButton}" Width="32" Height="28"
                                    Padding="0" Click="FirstPage_Click"/>
                            <Button Content="‹" Style="{StaticResource SecondaryButton}" Width="32" Height="28"
                                    Padding="0" Click="PrevPage_Click" Margin="4,0"/>
                            <TextBlock x:Name="PageText" Text="第1页/共1页"
                                       FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center" Margin="4,0"/>
                            <Button Content="›" Style="{StaticResource SecondaryButton}" Width="32" Height="28"
                                    Padding="0" Click="NextPage_Click" Margin="4,0"/>
                            <Button Content="»" Style="{StaticResource SecondaryButton}" Width="32" Height="28"
                                    Padding="0" Click="LastPage_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
