<Page x:Class="DbSyncTool.Views.Pages.DataCallPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="数据调用配置" Background="{StaticResource PageBgBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource PageTitle}" Text="数据调用配置"/>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="同步方向：" Style="{StaticResource FormLabel}"/>
                <ComboBox Grid.Column="1" x:Name="SearchDirection" Style="{StaticResource InputComboBox}" SelectedIndex="0">
                    <ComboBoxItem Content="全部"/>
                    <ComboBoxItem Content="SQL Server → MySQL"/>
                    <ComboBoxItem Content="MySQL → SQL Server"/>
                    <ComboBoxItem Content=" SQL Server→ SQL Server"/>
                    <ComboBoxItem Content=" MySQL →MySQL "/>
                </ComboBox>
                <TextBlock Grid.Column="2" Text="类型：" Style="{StaticResource FormLabel}" Margin="12,0,8,0"/>
                <ComboBox Grid.Column="3" x:Name="SearchCallType" Style="{StaticResource InputComboBox}" SelectedIndex="0">
                    <ComboBoxItem Content="全部"/>
                    <ComboBoxItem Content="直接插入"/>
                    <ComboBoxItem Content="API处理"/>
                </ComboBox>
                <TextBlock Grid.Column="4" Text="名称：" Style="{StaticResource FormLabel}" Margin="12,0,8,0"/>
                <TextBox Grid.Column="5" x:Name="SearchName" Style="{StaticResource InputTextBox}"/>
                <StackPanel Grid.Column="7" Orientation="Horizontal">
                    <Button Style="{StaticResource PrimaryButton}" Content="🔍 搜索" Click="Search_Click"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="重置" Click="Reset_Click" Margin="8,0,0,0"/>
                </StackPanel>
                <Button Grid.Column="9" Style="{StaticResource PrimaryButton}" Content="＋ 新增配置" Click="AddNew_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <DataGrid Grid.Row="0" x:Name="DataCallGrid" Style="{StaticResource ModernDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="配置名称" Binding="{Binding ConfigName}" Width="160"/>
                        <DataGridTemplateColumn Header="同步方向" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3" Padding="6,2" Margin="4,8"
                                            Background="#BEE3F8">
                                        <TextBlock Text="{Binding SyncDirectionDisplay}" FontSize="11"
                                                   Foreground="#2B6CB0"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="类型" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3" Padding="6,2" Margin="4,8"
                                            Background="{Binding CallTypeBg}">
                                        <TextBlock Text="{Binding CallTypeDisplay}" FontSize="11"
                                                   Foreground="{Binding CallTypeFg}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="字典匹配" Binding="{Binding DictMatchName}" Width="*"/>
                        <DataGridTextColumn Header="API配置" Binding="{Binding ApiName}" Width="100"/>
                        <DataGridTextColumn Header="创建时间" Binding="{Binding CreateTime, StringFormat='yyyy-MM-dd HH:mm'}" Width="130"/>
                        <DataGridTemplateColumn Header="操作" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4,0">
                                        <Button Content="编辑" Style="{StaticResource SecondaryButton}"
                                                Height="26" Padding="10,0" Margin="0,0,6,0"
                                                Click="Edit_Click" Tag="{Binding Id}"/>
                                        <Button Content="删除" Style="{StaticResource DangerButton}"
                                                Height="26" Padding="10,0"
                                                Click="Delete_Click" Tag="{Binding Id}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <Border Grid.Row="1" Padding="16,8" BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="0,1,0,0">
                    <TextBlock x:Name="TotalCountText" Text="共 0 条" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
