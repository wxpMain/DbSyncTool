<Window x:Class="DbSyncTool.Views.Dialogs.ProcConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="存储过程配置" Width="1100" Height="780"
        WindowStartupLocation="CenterOwner" Background="White">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="48"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="56"/>
    </Grid.RowDefinitions>

    <!-- 标题栏 -->
    <Border Grid.Row="0" Background="{StaticResource AccentBlueBrush}">
      <Grid Margin="16,0">
        <TextBlock x:Name="DialogTitle" Text="新增存储过程配置" FontSize="15"
                   FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
        <Button Content="✕" HorizontalAlignment="Right" Background="Transparent"
                BorderThickness="0" Foreground="White" FontSize="16" Cursor="Hand"
                Click="Close_Click"/>
      </Grid>
    </Border>

    <!-- 主体：左配置 | 右字段映射 -->
    <Grid Grid.Row="1" Margin="16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="400"/>
        <ColumnDefinition Width="12"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- ===== 左侧：配置项 ===== -->
      <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,4,0,4">

          <!-- 基础信息 -->
          <TextBlock Text="配置名称 *" Style="{StaticResource FormLabel}" Margin="0,0,0,4"/>
          <TextBox x:Name="TxtName" Style="{StaticResource InputTextBox}" Margin="0,0,0,12"/>

          <TextBlock Text="配置说明" Style="{StaticResource FormLabel}" Margin="0,0,0,4"/>
          <TextBox x:Name="TxtDesc" Style="{StaticResource InputTextBox}" Margin="0,0,0,12"/>

          <Separator Margin="0,0,0,12"/>

          <!-- 源库 -->
          <TextBlock Text="源数据库 *" Style="{StaticResource FormLabel}" Margin="0,0,0,4"/>
          <ComboBox x:Name="CmbSrcDb" Style="{StaticResource InputComboBox}"
                    Margin="0,0,0,8" SelectionChanged="CmbSrcDb_Changed"/>

          <TextBlock Text="源库查询SQL * （SELECT语句，从源库读数据）"
                     Style="{StaticResource FormLabel}" Margin="0,0,0,4"/>
          <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="8"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" FontSize="11" Foreground="#718096" TextWrapping="Wrap"
                       Text="支持多表JOIN，结果列的别名即为源字段名"/>
            <Button Grid.Column="2" x:Name="BtnValidateSql" Content="验证SQL"
                    Style="{StaticResource SecondaryButton}" Padding="10,4" FontSize="12"
                    IsEnabled="False" Click="BtnValidateSql_Click"/>
          </Grid>
          <TextBox x:Name="TxtSrcSql" Style="{StaticResource InputTextBox}"
                   Height="140" AcceptsReturn="True" TextWrapping="Wrap"
                   FontFamily="Consolas" FontSize="12" VerticalScrollBarVisibility="Auto"
                   Margin="0,0,0,4"
                   ToolTip="示例：&#10;SELECT inv.code AS Code, inv.name AS Title&#10;FROM AA_Inventory inv&#10;WHERE inv.disabled = 0"/>
          <Button Content="▶ 解析SQL列名 → 自动生成映射" Style="{StaticResource SecondaryButton}"
                  Padding="12,5" FontSize="12" Click="BtnParseSql_Click" Margin="0,0,0,12"/>

          <Separator Margin="0,0,0,12"/>

          <!-- 输出方式 -->
          <TextBlock Text="输出方式 *" Style="{StaticResource FormLabel}" Margin="0,0,0,6"/>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton x:Name="RdoDirect" Content="直接写入目标表" IsChecked="True"
                         FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                         Checked="OutputMode_Changed"/>
            <RadioButton x:Name="RdoApi" Content="调用API写入" Margin="20,0,0,0"
                         FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                         Checked="OutputMode_Changed"/>
          </StackPanel>

          <!-- API模式配置 -->
          <Border x:Name="PnlApiMode" Visibility="Collapsed"
                  Background="#EBF8FF" BorderBrush="#90CDF4" BorderThickness="1"
                  CornerRadius="4" Padding="10,8" Margin="0,0,0,12">
            <StackPanel>
              <TextBlock Text="API配置 *" Style="{StaticResource FormLabel}" Margin="0,0,0,4"/>
              <ComboBox x:Name="CmbApi" Style="{StaticResource InputComboBox}" Margin="0,0,0,8"/>
              <TextBlock Text="查重/映射目标数据库（MySQL）" Style="{StaticResource FormLabel}" Margin="0,0,0,4"/>
              <ComboBox x:Name="CmbApiDstDb" Style="{StaticResource InputComboBox}" Margin="0,0,0,8"
                        ToolTip="用于批量查重和Code→Id映射，选MySQL目标库"/>
              <TextBlock Text="批次模式" Style="{StaticResource FormLabel}" Margin="0,0,0,6"/>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <RadioButton x:Name="RdoSingle" Content="逐条调用（每条记录单独POST）"
                             IsChecked="True" FontSize="12" GroupName="ApiBodyMode"
                             Foreground="{StaticResource TextPrimaryBrush}"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="RdoBatch" Content="批量调用（整批打包为JSON数组POST）"
                             FontSize="12" GroupName="ApiBodyMode"
                             Foreground="{StaticResource TextPrimaryBrush}"/>
              </StackPanel>
              <!-- BOM分组键 -->
              <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="80"/>
                  <ColumnDefinition Width="120"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="分组字段：" Style="{StaticResource FormLabel}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" x:Name="TxtBomGroupKey" Style="{StaticResource InputTextBox}"
                         ToolTip="BOM批量接口专用：填写分组字段名（如 RootCode），同一组的数据打包成数组一次POST&#10;普通逐条接口留空"/>
                <TextBlock Grid.Column="2" Text="填RootCode可将同一BOM的所有行打包为数组POST" FontSize="11"
                           Foreground="#718096" VerticalAlignment="Center" Margin="8,0,0,0"/>
              </Grid>

              <!-- 子数组模板 -->
              <TextBlock Text="子数组模板（可选）" Style="{StaticResource FormLabel}" Margin="0,0,0,4"/>
              <TextBox x:Name="TxtDetailsTemplate" Style="{StaticResource InputTextBox}"
                       Height="80" AcceptsReturn="True" TextWrapping="Wrap"
                       FontFamily="Consolas" FontSize="12"
                       VerticalScrollBarVisibility="Auto" Margin="0,0,0,4"
                       ToolTip="主表+明细嵌套结构时使用：主模板中用[[details]]占位，此处填明细单行模板&#10;例：{&quot;productCode&quot;:&quot;{{productCode}}&quot;,&quot;qty&quot;:{{qty}}}"/>
              <TextBlock Text="主模板中用 [[details]] 占位，此处填明细单行模板" FontSize="11"
                         Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>

              <!-- 并发数 -->
              <Grid Margin="0,8,0,8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="80"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="并发数：" Style="{StaticResource FormLabel}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" x:Name="TxtApiConcurrency" Style="{StaticResource InputTextBox}"
                         Text="5" ToolTip="同时发送的请求数，建议3-10"/>
                <TextBlock Grid.Column="2" Text="（建议3-10，默认5）" FontSize="11"
                           Foreground="#718096" VerticalAlignment="Center" Margin="8,0,0,0"/>
              </Grid>
              <Separator Margin="0,0,0,8"/>
              <CheckBox x:Name="ChkApiUpsert" Content="启用查重（目标表已存在则跳过，不重复调API）"
                        FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"
                        Checked="ChkApiUpsert_Changed" Unchecked="ChkApiUpsert_Changed"/>
              <Border x:Name="PnlApiUpsert" Visibility="Collapsed" Margin="0,8,0,0">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="查重表" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                  <TextBox Grid.Column="1" x:Name="TxtApiUpsertTable" Style="{StaticResource InputTextBox}"
                           ToolTip="目标库中的表名，如：product_info"/>
                  <TextBlock Grid.Column="3" Text="唯一键" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                  <TextBox Grid.Column="4" x:Name="TxtApiUpsertKey" Style="{StaticResource InputTextBox}"
                           ToolTip="唯一键字段名，多个用逗号分隔，如：Code"/>
                </Grid>
              </Border>
            </StackPanel>
          </Border>

          <!-- 直接写入模式：目标库 -->
          <Border x:Name="PnlDirectMode" Visibility="Visible">
            <StackPanel>

          <TextBlock Text="目标数据库 *" Style="{StaticResource FormLabel}" Margin="0,0,0,4"/>
          <ComboBox x:Name="CmbDstDb" Style="{StaticResource InputComboBox}"
                    Margin="0,0,0,8" SelectionChanged="CmbDstDb_Changed"/>

          <TextBlock Text="目标表 *" Style="{StaticResource FormLabel}" Margin="0,0,0,4"/>
          <Grid Margin="0,0,0,12" x:Name="DstTableGrid">
            <!-- 搜索输入框 -->
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="28"/>
              </Grid.ColumnDefinitions>
              <TextBox x:Name="TxtDstTable" Style="{StaticResource InputTextBox}"
                       TextChanged="TxtDstTable_TextChanged"
                       GotFocus="TxtDstTable_GotFocus"
                       LostFocus="TxtDstTable_LostFocus"
                       ToolTip="输入表名搜索"/>
              <TextBlock Grid.Column="0" Text="🔍 输入表名搜索..." FontSize="12" Foreground="#A0AEC0"
                         IsHitTestVisible="False" VerticalAlignment="Center" Margin="10,0">
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding Text, ElementName=TxtDstTable}" Value="">
                        <Setter Property="Visibility" Value="Visible"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
              <Button Grid.Column="1" Content="▼" FontSize="10" Background="Transparent"
                      BorderThickness="0,1,1,1" BorderBrush="#CBD5E0"
                      Click="BtnDstTableDropDown_Click" Cursor="Hand"/>
            </Grid>
            <!-- 下拉列表 Popup -->
            <Popup x:Name="DstTablePopup" PlacementTarget="{Binding ElementName=TxtDstTable}"
                   Placement="Bottom" StaysOpen="False"
                   Width="{Binding ActualWidth, ElementName=DstTableGrid}">
              <Border BorderBrush="#CBD5E0" BorderThickness="1" Background="White"
                      MaxHeight="200">
                <ListBox x:Name="LstDstTable" BorderThickness="0"
                         SelectionChanged="LstDstTable_SelectionChanged"
                         FontSize="12"/>
              </Border>
            </Popup>
          </Grid>

            </StackPanel>
          </Border>

          <Separator Margin="0,0,0,12"/>

          <!-- 同步控制 -->
          <TextBlock Text="同步模式" Style="{StaticResource FormLabel}" Margin="0,0,0,6"/>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton x:Name="RdoFull" Content="全量" IsChecked="True"
                         FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
            <RadioButton x:Name="RdoIncremental" Content="增量" Margin="20,0,0,0"
                         Checked="SyncMode_Changed" Unchecked="SyncMode_Changed"
                         FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
          </StackPanel>

          <TextBlock x:Name="LblIncField" Text="增量字段" Style="{StaticResource FormLabel}"
                     Visibility="Collapsed" Margin="0,0,0,4"/>
          <TextBox x:Name="TxtIncField" Style="{StaticResource InputTextBox}"
                   Visibility="Collapsed" Margin="0,0,0,12"
                   ToolTip="源SQL中的时间戳列别名，如：UpdateTime"/>

          <TextBlock Text="批次大小" Style="{StaticResource FormLabel}" Margin="0,0,0,4"/>
          <TextBox x:Name="TxtBatch" Style="{StaticResource InputTextBox}"
                   Text="500" Margin="0,0,0,12"/>

          <!-- Upsert -->
          <CheckBox x:Name="ChkUpsert" Content="启用 Upsert（查重后插入或更新）"
                    FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                    Checked="ChkUpsert_Changed" Unchecked="ChkUpsert_Changed"
                    Margin="0,0,0,6"/>
          <Border x:Name="PnlUpsert" Visibility="Collapsed" Background="#FFFAF0"
                  BorderBrush="#F6AD55" BorderThickness="1" CornerRadius="4"
                  Padding="10,8" Margin="0,0,0,12">
            <StackPanel>
              <TextBlock FontSize="11" Foreground="#7B341E" Margin="0,0,0,4"
                         Text="目标表唯一键字段（多个用英文逗号分隔）"/>
              <TextBox x:Name="TxtUpsertKey" Style="{StaticResource InputTextBox}"
                       ToolTip="如：Code 或 BillNo,LineNo"/>
            </StackPanel>
          </Border>

          <!-- 同步后SQL -->
          <CheckBox x:Name="ChkPostSql" Content="同步后执行SQL（修正/存储过程）"
                    FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                    Checked="ChkPostSql_Changed" Unchecked="ChkPostSql_Changed"
                    Margin="0,0,0,6"/>
          <Border x:Name="PnlPostSql" Visibility="Collapsed" Background="#EBF8FF"
                  BorderBrush="#90CDF4" BorderThickness="1" CornerRadius="4"
                  Padding="10,8" Margin="0,0,0,12">
            <TextBox x:Name="TxtPostSql" Style="{StaticResource InputTextBox}"
                     Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                     FontFamily="Consolas" FontSize="12"
                     VerticalScrollBarVisibility="Auto"
                     ToolTip="在目标库执行，如：CALL sp_fix_bom_sync();"/>
          </Border>

          <!-- 回写SQL -->
          <CheckBox x:Name="ChkWriteBack"
                    Content="接口成功后回写SQL（可选）"
                    FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                    Margin="0,0,0,6"
                    Checked="ChkWriteBack_Changed"
                    Unchecked="ChkWriteBack_Changed"/>
          <Border x:Name="PnlWriteBack" Visibility="Collapsed"
                  Background="#F0FFF4" BorderBrush="#C6F6D5"
                  BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
            <StackPanel>
              <TextBlock Text="回写目标数据库" Style="{StaticResource FormLabel}" Margin="0,0,0,4"/>
              <ComboBox x:Name="CmbWriteBackDb"
                        Style="{StaticResource InputComboBox}"
                        Margin="0,0,0,8"/>
              <TextBlock Style="{StaticResource FormLabel}" Margin="0,0,0,4">
                回写SQL模板
                <Run Foreground="#718096" FontSize="11">（支持 {{字段名}} 占位符，{{now}} = 当前时间）</Run>
              </TextBlock>
              <TextBox x:Name="TxtWriteBackSql"
                       Style="{StaticResource InputTextBox}"
                       Height="80" AcceptsReturn="True"
                       TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"
                       VerticalScrollBarVisibility="Auto"
                       ToolTip="示例：UPDATE TPADEA SET DEA974=1, DEA975='{{now}}' WHERE DEA001='{{code}}'"/>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>

      <!-- ===== 右侧：字段映射 ===== -->
      <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <!-- 标题+操作 -->
          <Border Grid.Row="0" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="14,10">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Orientation="Horizontal">
                <Border Width="4" Height="14" Background="#3182CE" CornerRadius="2" Margin="0,0,8,0"/>
                <TextBlock Text="字段映射" FontWeight="SemiBold" FontSize="13"
                           Foreground="#2D3748" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtMappingCount" Text="（0 对）" FontSize="12"
                           Foreground="#718096" VerticalAlignment="Center" Margin="6,0,0,0"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="＋ 添加行" Style="{StaticResource PrimaryButton}"
                        Padding="10,4" FontSize="12" Click="AddRow_Click" Margin="0,0,8,0"/>
                <Button Content="清空" Style="{StaticResource SecondaryButton}"
                        Padding="10,4" FontSize="12" Click="ClearRows_Click"/>
              </StackPanel>
            </Grid>
          </Border>

          <!-- 列头 -->
          <Grid Grid.Row="1" Background="#F7FAFC" Margin="0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="28"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="100"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="100"/>
              <ColumnDefinition Width="44"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="#" FontSize="11" FontWeight="SemiBold"
                       Foreground="#718096" HorizontalAlignment="Center" Margin="0,6"/>
            <TextBlock Grid.Column="1" Text="源字段别名（SQL中的AS名）" FontSize="11"
                       FontWeight="SemiBold" Foreground="#2B6CB0" Margin="8,6"/>
            <TextBlock Grid.Column="2" Text="类型" FontSize="11" FontWeight="SemiBold"
                       Foreground="#718096" Margin="4,6"/>
            <TextBlock Grid.Column="3" Text="目标字段" FontSize="11"
                       FontWeight="SemiBold" Foreground="#276749" Margin="8,6"/>
            <TextBlock Grid.Column="4" Text="固定值（可选）" FontSize="11"
                       FontWeight="SemiBold" Foreground="#718096" Margin="4,6"/>
            <TextBlock Grid.Column="5" Text="删" FontSize="11" FontWeight="SemiBold"
                       Foreground="#718096" HorizontalAlignment="Center" Margin="0,6"/>
          </Grid>

          <!-- 映射行列表 -->
          <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="MappingPanel">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid MinHeight="38" Background="White">
                    <Grid.Style>
                      <Style TargetType="Grid">
                        <Style.Triggers>
                          <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F7FAFC"/>
                          </Trigger>
                        </Style.Triggers>
                      </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="28"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="100"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="100"/>
                      <ColumnDefinition Width="44"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding SortOrder}" FontSize="11"
                               Foreground="#A0AEC0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding SourceAlias, UpdateSourceTrigger=PropertyChanged}"
                             Margin="4,3" FontSize="12" BorderThickness="0,0,0,1"
                             BorderBrush="#E2E8F0" Background="Transparent"
                             ToolTip="SQL中的AS别名，如：Code&#10;留空则使用右侧固定值"/>
                    <ComboBox Grid.Column="2" SelectedItem="{Binding MappingType}"
                              Margin="2,3" FontSize="11" BorderThickness="0,0,0,1"
                              BorderBrush="#E2E8F0">
                      <ComboBoxItem Content="Field"/>
                      <ComboBoxItem Content="Const"/>
                    </ComboBox>
                    <TextBox Grid.Column="3" Text="{Binding TargetField, UpdateSourceTrigger=PropertyChanged}"
                             Margin="4,3" FontSize="12" BorderThickness="0,0,0,1"
                             BorderBrush="#E2E8F0" Background="Transparent"
                             ToolTip="目标表字段名"/>
                    <TextBox Grid.Column="4" Text="{Binding DefaultValue, UpdateSourceTrigger=PropertyChanged}"
                             Margin="2,3" FontSize="12" BorderThickness="0,0,0,1"
                             BorderBrush="#E2E8F0" Background="Transparent"
                             ToolTip="固定值，如：0、1、个&#10;MappingType=Const时必填"/>
                    <Button Grid.Column="5" Content="✕" Tag="{Binding}"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#FC8181" FontSize="13" Cursor="Hand"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Click="RemoveRow_Click"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>

    <!-- 底部按钮 -->
    <Border Grid.Row="2" BorderBrush="{StaticResource BorderGrayBrush}"
            BorderThickness="0,1,0,0" Background="White">
      <Grid Margin="24,0">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Content="取消" Style="{StaticResource SecondaryButton}"
                  Click="Cancel_Click" Margin="0,0,8,0"/>
          <Button Content="保存配置" Style="{StaticResource PrimaryButton}" Click="Save_Click"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
