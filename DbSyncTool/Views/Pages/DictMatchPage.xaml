<Page x:Class="DbSyncTool.Views.Pages.DictMatchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="字典匹配" Background="{StaticResource PageBgBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource PageTitle}" Text="字典匹配配置"/>

        <!-- 搜索区 -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="配置名称：" Style="{StaticResource FormLabel}"/>
                <TextBox Grid.Column="1" x:Name="SearchName" Style="{StaticResource InputTextBox}"/>
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Style="{StaticResource PrimaryButton}" Content="🔍 搜索" Click="Search_Click"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="重置" Click="Reset_Click" Margin="8,0,0,0"/>
                </StackPanel>
                <Button Grid.Column="5" Style="{StaticResource PrimaryButton}" Content="＋ 新增映射" Click="AddNew_Click"/>
            </Grid>
        </Border>

        <!-- 列表 -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <DataGrid Grid.Row="0" x:Name="MatchGrid" Style="{StaticResource ModernDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="配置名称" Binding="{Binding ConfigName}" Width="160"/>
                        <DataGridTextColumn Header="源数据库" Binding="{Binding SourceDbName}" Width="140"/>
                        <DataGridTextColumn Header="目标数据库" Binding="{Binding TargetDbName}" Width="140"/>
                        <DataGridTextColumn Header="同步方向" Binding="{Binding SyncDirectionDisplay}" Width="160"/>
                        <DataGridTextColumn Header="字段映射数" Binding="{Binding DetailsCount}" Width="90"/>
                        <DataGridTextColumn Header="创建时间" Binding="{Binding CreateTime, StringFormat='yyyy-MM-dd HH:mm'}" Width="130"/>
                        <DataGridTemplateColumn Header="操作" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4,0">
                                        <Button Content="编辑" Style="{StaticResource SecondaryButton}"
                                                Height="26" Padding="10,0" Margin="0,0,6,0"
                                                Click="Edit_Click" Tag="{Binding Id}"/>
                                        <Button Content="删除" Style="{StaticResource DangerButton}"
                                                Height="26" Padding="10,0"
                                                Click="Delete_Click" Tag="{Binding Id}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <Border Grid.Row="1" Padding="16,8" BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="0,1,0,0">
                    <TextBlock x:Name="TotalCountText" Text="共 0 条" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
