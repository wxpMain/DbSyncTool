<Window x:Class="DbSyncTool.Views.Dialogs.ApiConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="API配置" Width="600" Height="560"
        WindowStartupLocation="CenterOwner" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="56"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource AccentBlueBrush}">
            <Grid Margin="16,0">
                <TextBlock x:Name="DialogTitle" Text="新增API配置" FontSize="15" FontWeight="SemiBold"
                           Foreground="White" VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right" Background="Transparent"
                        BorderThickness="0" Foreground="White" FontSize="16" Cursor="Hand"
                        Click="Close_Click"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="24,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="API名称 *" Style="{StaticResource FormLabel}"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtApiName" Style="{StaticResource InputTextBox}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="请求地址 *" Style="{StaticResource FormLabel}"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtUrl" Style="{StaticResource InputTextBox}"
                         ToolTip="完整URL，如 https://api.example.com/v1/users"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="请求方法 *" Style="{StaticResource FormLabel}"/>
                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="CmbMethod" Style="{StaticResource InputComboBox}"
                          SelectionChanged="Method_Changed">
                    <ComboBoxItem Content="POST" IsSelected="True"/>
                    <ComboBoxItem Content="GET"/>
                    <ComboBoxItem Content="PUT"/>
                    <ComboBoxItem Content="DELETE"/>
                </ComboBox>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="超时(秒)" Style="{StaticResource FormLabel}"/>
                <TextBox Grid.Row="6" Grid.Column="1" x:Name="TxtTimeout" Style="{StaticResource InputTextBox}" Text="30"/>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="请求头" Style="{StaticResource FormLabel}"/>
                <TextBox Grid.Row="8" Grid.Column="1" x:Name="TxtHeaders" Style="{StaticResource InputTextBox}"
                         Height="60" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         ToolTip="格式：Key: Value，每行一个"/>

                <TextBlock Grid.Row="10" Grid.Column="0" Text="请求体模板" Style="{StaticResource FormLabel}"
                           x:Name="LblBody"/>
                <TextBox Grid.Row="10" Grid.Column="1" x:Name="TxtBody" Style="{StaticResource InputTextBox}"
                         Height="80" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         ToolTip="JSON格式，使用${fieldName}作为占位符"/>

                <TextBlock Grid.Row="12" Grid.Column="0" Text="JSON路径" Style="{StaticResource FormLabel}"/>
                <TextBox Grid.Row="12" Grid.Column="1" x:Name="TxtJsonPath" Style="{StaticResource InputTextBox}"
                         ToolTip="如：$.data.result"/>

                <TextBlock Grid.Row="14" Grid.Column="0" Text="成功状态码" Style="{StaticResource FormLabel}"/>
                <TextBox Grid.Row="14" Grid.Column="1" x:Name="TxtSuccessCodes" Style="{StaticResource InputTextBox}" Text="200"/>

                <!-- 自动登录配置 -->
                <CheckBox Grid.Row="16" Grid.Column="0" Grid.ColumnSpan="2"
                          x:Name="ChkAutoLogin" Content="启用自动登录获取Token（Token过期时自动重新登录）"
                          FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"
                          Checked="ChkAutoLogin_Changed" Unchecked="ChkAutoLogin_Changed"/>

                <Border Grid.Row="18" Grid.Column="0" Grid.ColumnSpan="2"
                        x:Name="PnlAutoLogin" Visibility="Collapsed"
                        Background="#EBF8FF" BorderBrush="#90CDF4" BorderThickness="1"
                        CornerRadius="4" Padding="12,10">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="8"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="8"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="8"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="100"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="登录地址 *" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtLoginUrl"
                             Style="{StaticResource InputTextBox}"
                             ToolTip="如：http://218.78.135.17:8280/admin/user/login"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="登录请求体 *" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtLoginBody"
                             Style="{StaticResource InputTextBox}"
                             Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                             FontFamily="Consolas" FontSize="12"
                             VerticalScrollBarVisibility="Auto"
                             ToolTip="JSON格式，如：{&quot;username&quot;:&quot;admin&quot;,&quot;password&quot;:&quot;e10adc...&quot;}"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Token路径 *" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="TxtTokenPath"
                             Style="{StaticResource InputTextBox}"
                             Text="response.xtoken"
                             ToolTip="从登录响应中取Token的路径，如：response.xtoken"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Header Key" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="6" Grid.Column="1" x:Name="TxtTokenHeaderKey"
                             Style="{StaticResource InputTextBox}"
                             Text="X-token"
                             ToolTip="Token放入请求头的字段名，如：X-token"/>
                  </Grid>
                </Border>

                <!-- 测试结果 -->
                <TextBlock Grid.Row="20" Grid.Column="0" Grid.ColumnSpan="2"
                           x:Name="TestResultText" FontSize="12" Margin="0,4,0,0"/>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2" BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="0,1,0,0" Background="White">
            <Grid Margin="24,0">
                <Button Content="测试调用" Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Left" Click="TestApi_Click"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" Style="{StaticResource SecondaryButton}" Click="Cancel_Click" Margin="0,0,8,0"/>
                    <Button Content="保存" Style="{StaticResource PrimaryButton}" Click="Save_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
