<Page x:Class="DbSyncTool.Views.Pages.TaskConfigPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="任务配置" Background="{StaticResource PageBgBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource PageTitle}" Text="任务配置管理"/>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="任务名称：" Style="{StaticResource FormLabel}"/>
                <TextBox Grid.Column="1" x:Name="SearchName" Style="{StaticResource InputTextBox}"/>
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Style="{StaticResource PrimaryButton}" Content="🔍 搜索" Click="Search_Click"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="重置" Click="Reset_Click" Margin="8,0,0,0"/>
                </StackPanel>
                <Button Grid.Column="5" Style="{StaticResource PrimaryButton}" Content="＋ 新增任务" Click="AddNew_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <DataGrid Grid.Row="0" x:Name="TaskGrid" Style="{StaticResource ModernDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="任务名称" Binding="{Binding TaskName}" Width="160"/>
                        <DataGridTextColumn Header="关联数据调用" Binding="{Binding DataCallName}" Width="160"/>
                        <DataGridTextColumn Header="触发方式" Binding="{Binding TriggerTypeDisplay}" Width="80"/>
                        <DataGridTextColumn Header="下次执行时间" Binding="{Binding NextRunDisplay}" Width="140"/>
                        <DataGridTemplateColumn Header="状态" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3" Padding="6,2" Margin="4,8"
                                            Background="{Binding StatusBg}">
                                        <TextBlock Text="{Binding StatusDisplay}" FontSize="11"
                                                   Foreground="{Binding StatusFg}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="创建时间" Binding="{Binding CreateTime, StringFormat='yyyy-MM-dd HH:mm'}" Width="130"/>
                        <DataGridTemplateColumn Header="操作" Width="220">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4,0">
                                        <Button Content="立即执行" Style="{StaticResource PrimaryButton}"
                                                Height="26" Padding="8,0" Margin="0,0,4,0"
                                                Click="RunNow_Click" Tag="{Binding Id}"/>
                                        <Button Content="编辑" Style="{StaticResource SecondaryButton}"
                                                Height="26" Padding="8,0" Margin="0,0,4,0"
                                                Click="Edit_Click" Tag="{Binding Id}"/>
                                        <Button Content="删除" Style="{StaticResource DangerButton}"
                                                Height="26" Padding="8,0"
                                                Click="Delete_Click" Tag="{Binding Id}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <Border Grid.Row="1" Padding="16,8" BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="0,1,0,0">
                    <TextBlock x:Name="TotalCountText" Text="共 0 条" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
