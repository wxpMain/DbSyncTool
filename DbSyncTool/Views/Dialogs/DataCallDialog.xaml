<Window x:Class="DbSyncTool.Views.Dialogs.DataCallDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="数据调用配置" Width="860" Height="680"
        WindowStartupLocation="CenterOwner" Background="White">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="48"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="56"/>
    </Grid.RowDefinitions>

    <!-- 标题栏 -->
    <Border Grid.Row="0" Background="{StaticResource AccentBlueBrush}">
      <Grid Margin="16,0">
        <TextBlock x:Name="DialogTitle" Text="新增数据调用配置" FontSize="15" FontWeight="SemiBold"
                   Foreground="White" VerticalAlignment="Center"/>
        <Button Content="✕" HorizontalAlignment="Right" Background="Transparent"
                BorderThickness="0" Foreground="White" FontSize="16" Cursor="Hand"
                Click="Close_Click"/>
      </Grid>
    </Border>

    <!-- 主体：左配置 | 右映射预览 -->
    <Grid Grid.Row="1" Margin="16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="340"/>
        <ColumnDefinition Width="12"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- ===== 左侧：配置表单 ===== -->
      <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,4,0,4">

          <!-- 配置名称 -->
          <TextBlock Text="配置名称 *" Style="{StaticResource FormLabel}" Margin="0,0,0,4"/>
          <TextBox x:Name="TxtName" Style="{StaticResource InputTextBox}" Margin="0,0,0,12"/>

          <!-- 同步方向 -->
          <TextBlock Text="同步方向 *" Style="{StaticResource FormLabel}" Margin="0,0,0,4"/>
          <ComboBox x:Name="CmbDirection" Style="{StaticResource InputComboBox}"
                    SelectedIndex="0" Margin="0,0,0,12">
            <ComboBoxItem Content="SQL Server → MySQL"/>
            <ComboBoxItem Content="MySQL → SQL Server"/>
            <ComboBoxItem Content="SQL Server → SQL Server"/>
            <ComboBoxItem Content="MySQL → MySQL"/>
          </ComboBox>

          <!-- 调用方式 -->
          <TextBlock Text="调用方式 *" Style="{StaticResource FormLabel}" Margin="0,0,0,6"/>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton x:Name="RdoDirect" Content="直接插入" IsChecked="True"
                         Checked="CallType_Changed" FontSize="13"
                         Foreground="{StaticResource TextPrimaryBrush}"/>
            <RadioButton x:Name="RdoApi" Content="调用 API" Margin="20,0,0,0"
                         Checked="CallType_Changed" FontSize="13"
                         Foreground="{StaticResource TextPrimaryBrush}"/>
            <RadioButton x:Name="RdoScript" Content="脚本执行" Margin="20,0,0,0"
                         Checked="CallType_Changed" FontSize="13"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         ToolTip="直接在目标库执行SQL脚本，不走字段映射"/>
          </StackPanel>

          <!-- 脚本执行模式 -->
          <Border x:Name="PnlScript" Visibility="Collapsed"
                  Background="#F0FFF4" BorderBrush="#9AE6B4" BorderThickness="1"
                  CornerRadius="4" Padding="10,8" Margin="0,0,0,12">
            <StackPanel>
              <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock FontSize="11" Foreground="#276749" TextWrapping="Wrap"
                           Text="在目标库直接执行SQL脚本（支持 INSERT/UPDATE/CALL/EXEC 等）&#10;多条语句用分号分隔，每条语句单独执行并显示进度"/>
                <Button Grid.Column="1" Content="验证语法" Style="{StaticResource SecondaryButton}"
                        Padding="10,4" FontSize="12" Click="BtnValidateScript_Click"/>
              </Grid>
              <TextBox x:Name="TxtScriptSql"
                       Style="{StaticResource InputTextBox}"
                       Height="120" AcceptsReturn="True" TextWrapping="Wrap"
                       FontFamily="Consolas" FontSize="12"
                       VerticalScrollBarVisibility="Auto"
                       ToolTip="示例：&#10;INSERT INTO product_info(Code,Title,...) SELECT code,name,... FROM AA_Inventory WHERE disabled=0;&#10;CALL sp_fix_bom_sync();"/>
            </StackPanel>
          </Border>

          <Separator Margin="0,0,0,12"/>

          <!-- 字典匹配配置 -->
          <TextBlock Text="字典匹配配置 *" Style="{StaticResource FormLabel}" Margin="0,0,0,4"/>
          <ComboBox x:Name="CmbDictMatch" Style="{StaticResource InputComboBox}"
                    SelectionChanged="CmbDictMatch_Changed" Margin="0,0,0,12"/>

          <!-- API配置（仅API模式） -->
          <TextBlock x:Name="LblApi" Text="API 配置 *" Style="{StaticResource FormLabel}"
                     Margin="0,0,0,4" Visibility="Collapsed"/>
          <ComboBox x:Name="CmbApi" Style="{StaticResource InputComboBox}"
                    Margin="0,0,0,12" Visibility="Collapsed"/>

          <!-- 同步模式 -->
          <TextBlock Text="同步模式 *" Style="{StaticResource FormLabel}" Margin="0,0,0,6"/>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton x:Name="RdoFull" Content="全量" IsChecked="True"
                         FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
            <RadioButton x:Name="RdoIncremental" Content="增量" Margin="20,0,0,0"
                         Checked="SyncMode_Changed" Unchecked="SyncMode_Changed"
                         FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
          </StackPanel>

          <!-- 增量字段 -->
          <TextBlock x:Name="LblIncField" Text="增量字段" Style="{StaticResource FormLabel}"
                     Margin="0,0,0,4" Visibility="Collapsed"/>
          <TextBox x:Name="TxtIncField" Style="{StaticResource InputTextBox}"
                   Margin="0,0,0,12" Visibility="Collapsed"
                   ToolTip="时间戳或自增ID字段名，如：UpdateTime"/>

          <!-- WHERE 条件 -->
          <TextBlock Text="过滤条件（WHERE）" Style="{StaticResource FormLabel}" Margin="0,0,0,4"/>
          <TextBox x:Name="TxtWhere" Style="{StaticResource InputTextBox}"
                   Margin="0,0,0,12" ToolTip="附加到源查询的WHERE条件，如：Status = 1"/>

          <!-- 批次大小 -->
          <TextBlock Text="批次大小" Style="{StaticResource FormLabel}" Margin="0,0,0,4"/>
          <TextBox x:Name="TxtBatch" Style="{StaticResource InputTextBox}" Text="500" Margin="0,0,0,12"/>

          <Separator Margin="0,0,0,12"/>

          <!-- Upsert 模式 -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <CheckBox x:Name="ChkUpsert" FontSize="13" FontWeight="Medium"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      Content="启用 Upsert（查重后插入或更新）"
                      Checked="ChkUpsert_Changed" Unchecked="ChkUpsert_Changed"/>
          </StackPanel>
          <Border x:Name="PnlUpsert" Visibility="Collapsed"
                  Background="#FFFAF0" BorderBrush="#F6AD55" BorderThickness="1"
                  CornerRadius="4" Padding="10,8" Margin="0,0,0,0">
            <StackPanel>
              <TextBlock FontSize="11" Foreground="#7B341E" TextWrapping="Wrap" Margin="0,0,0,6"
                         Text="🔑 目标表唯一键字段（多个用英文逗号分隔）"/>
              <TextBox x:Name="TxtUpsertKey" Style="{StaticResource InputTextBox}"
                       ToolTip="如：BillNo 或 BillNo,ItemCode&#10;系统将以此字段查询目标库：&#10;· 不存在 → INSERT&#10;· 存在且数据不同 → UPDATE&#10;· 存在且数据相同 → 跳过（写日志）"/>
              <TextBlock FontSize="11" Foreground="#718096" Margin="0,6,0,0" TextWrapping="Wrap"
                         Text="⚠ 未启用时默认全量 INSERT，可能产生重复数据"/>
            </StackPanel>
          </Border>

          <Separator Margin="0,12,0,12"/>

          <!-- 同步后执行SQL -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <CheckBox x:Name="ChkPostSql" FontSize="13" FontWeight="Medium"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      Content="同步后执行SQL（修正/存储过程）"
                      Checked="ChkPostSql_Changed" Unchecked="ChkPostSql_Changed"/>
          </StackPanel>
          <Border x:Name="PnlPostSql" Visibility="Collapsed"
                  Background="#EBF8FF" BorderBrush="#90CDF4" BorderThickness="1"
                  CornerRadius="4" Padding="10,8">
            <StackPanel>
              <TextBlock FontSize="11" Foreground="#2C5282" TextWrapping="Wrap" Margin="0,0,0,6"
                         Text="在目标库（MySQL）执行，多条语句用分号分隔。&#10;示例：CALL sp_fix_bom_parentid(); 或直接写UPDATE语句"/>
              <TextBox x:Name="TxtPostSql" Style="{StaticResource InputTextBox}"
                       Height="80" AcceptsReturn="True" TextWrapping="Wrap"
                       FontFamily="Consolas" FontSize="12"
                       VerticalScrollBarVisibility="Auto"
                       ToolTip="同步完成后自动在目标库执行此SQL"/>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>

      <!-- ===== 右侧：映射关系预览 ===== -->
      <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <!-- 预览标题 -->
          <Border Grid.Row="0" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="14,10">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Orientation="Horizontal">
                <Border Width="4" Height="14" Background="#3182CE" CornerRadius="2" Margin="0,0,8,0"/>
                <TextBlock Text="字段映射预览" FontWeight="SemiBold" FontSize="13"
                           Foreground="#2D3748" VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock Grid.Column="1" x:Name="TxtPreviewHint"
                         Text="请先选择字典匹配配置" FontSize="11"
                         Foreground="#A0AEC0" VerticalAlignment="Center"/>
            </Grid>
          </Border>

          <!-- 列头 -->
          <Grid Grid.Row="1">
            <Grid.RowDefinitions>
              <RowDefinition Height="30"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#F7FAFC"
                  Margin="0" >
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="28"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="#" FontSize="11" FontWeight="SemiBold"
                         Foreground="#718096" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              <TextBlock Grid.Column="1" Text="源字段  /  源表" FontSize="11" FontWeight="SemiBold"
                         Foreground="#2B6CB0" VerticalAlignment="Center" Margin="8,0"/>
              <TextBlock Grid.Column="2" Text="→" FontSize="14" Foreground="#CBD5E0"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
              <TextBlock Grid.Column="3" Text="目标字段  /  目标表" FontSize="11" FontWeight="SemiBold"
                         Foreground="#276749" VerticalAlignment="Center" Margin="8,0"/>
            </Grid>

            <!-- 映射行 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
              <ItemsControl x:Name="PreviewPanel">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" MinHeight="48">
                      <Border.Style>
                        <Style TargetType="Border">
                          <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                              <Setter Property="Background" Value="#F7FAFC"/>
                            </Trigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="28"/>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="40"/>
                          <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 序号 -->
                        <TextBlock Grid.Column="0" Text="{Binding SortOrder}"
                                   FontSize="11" Foreground="#A0AEC0"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- 源字段（蓝色标签） -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,6">
                          <Border Background="#EBF4FF" CornerRadius="4" Padding="8,4"
                                  HorizontalAlignment="Left">
                            <StackPanel>
                              <TextBlock Text="{Binding SourceFieldName}" FontSize="12"
                                         FontWeight="SemiBold" Foreground="#2B6CB0"/>
                              <TextBlock FontSize="10" Foreground="#718096" Margin="0,1,0,0">
                                <TextBlock.Text>
                                  <MultiBinding StringFormat="{}{0}  ·  {1}">
                                    <Binding Path="SourceTableName"/>
                                    <Binding Path="SourceFieldType"/>
                                  </MultiBinding>
                                </TextBlock.Text>
                              </TextBlock>
                            </StackPanel>
                          </Border>
                        </StackPanel>

                        <!-- 箭头 -->
                        <TextBlock Grid.Column="2" Text="→" FontSize="18"
                                   Foreground="#CBD5E0" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                        <!-- 目标字段（绿色标签） -->
                        <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="8,6">
                          <Border Background="#F0FFF4" CornerRadius="4" Padding="8,4"
                                  HorizontalAlignment="Left">
                            <StackPanel>
                              <TextBlock Text="{Binding TargetFieldName}" FontSize="12"
                                         FontWeight="SemiBold" Foreground="#276749"/>
                              <TextBlock FontSize="10" Foreground="#718096" Margin="0,1,0,0">
                                <TextBlock.Text>
                                  <MultiBinding StringFormat="{}{0}  ·  {1}">
                                    <Binding Path="TargetTableName"/>
                                    <Binding Path="TargetFieldType"/>
                                  </MultiBinding>
                                </TextBlock.Text>
                              </TextBlock>
                            </StackPanel>
                          </Border>
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <!-- 底部按钮 -->
    <Border Grid.Row="2" BorderBrush="{StaticResource BorderGrayBrush}"
            BorderThickness="0,1,0,0" Background="White">
      <Grid Margin="24,0">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Content="取消" Style="{StaticResource SecondaryButton}"
                  Click="Cancel_Click" Margin="0,0,8,0"/>
          <Button Content="保存" Style="{StaticResource PrimaryButton}" Click="Save_Click"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
