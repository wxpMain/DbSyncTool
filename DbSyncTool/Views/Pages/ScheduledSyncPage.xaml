<Page x:Class="DbSyncTool.Views.Pages.ScheduledSyncPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="定时任务同步"
      Background="#F0F2F5"
      Unloaded="Page_Unloaded">

  <Page.Resources>
    <!-- 状态徽章转换器 -->
    <Style x:Key="StatusBadge" TargetType="Border">
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="10,3"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>
    <Style x:Key="RunButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
      <Setter Property="Padding" Value="10,5"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="MinWidth" Value="64"/>
    </Style>
  </Page.Resources>

  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="220"/>
    </Grid.RowDefinitions>

    <!-- 页标题 + 全局操作 -->
    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel>
        <TextBlock Text="定时任务同步" Style="{StaticResource PageTitle}"/>
        <TextBlock x:Name="TxtSchedulerStatus" Text="调度器状态：已停止" FontSize="12"
                   Foreground="#718096" Margin="0,4,0,0"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0">
        <Button x:Name="BtnStartScheduler" Content="▶ 启动调度器" Style="{StaticResource PrimaryButton}"
                Click="BtnStartScheduler_Click" Margin="0,0,8,0"/>
        <Button x:Name="BtnStopScheduler" Content="⏹ 停止调度器" Style="{StaticResource SecondaryButton}"
                Click="BtnStopScheduler_Click" IsEnabled="False" Margin="0,0,8,0"/>
        <Button Content="↺ 刷新" Style="{StaticResource SecondaryButton}" Click="BtnRefresh_Click"/>
      </StackPanel>
    </Grid>

    <!-- 汇总卡片 -->
    <Grid Grid.Row="1" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0" Padding="16,14">
        <StackPanel>
          <TextBlock Text="任务总数" FontSize="12" Foreground="#718096"/>
          <TextBlock x:Name="TxtTotalTasks" Text="0" FontSize="28" FontWeight="Bold"
                     Foreground="#2D3748" Margin="0,4,0,0"/>
        </StackPanel>
      </Border>

      <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="4,0" Padding="16,14">
        <StackPanel>
          <TextBlock Text="运行中" FontSize="12" Foreground="#718096"/>
          <TextBlock x:Name="TxtRunningTasks" Text="0" FontSize="28" FontWeight="Bold"
                     Foreground="#38A169" Margin="0,4,0,0"/>
        </StackPanel>
      </Border>

      <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="4,0" Padding="16,14">
        <StackPanel>
          <TextBlock Text="已禁用" FontSize="12" Foreground="#718096"/>
          <TextBlock x:Name="TxtDisabledTasks" Text="0" FontSize="28" FontWeight="Bold"
                     Foreground="#A0AEC0" Margin="0,4,0,0"/>
        </StackPanel>
      </Border>

      <Border Grid.Column="3" Style="{StaticResource CardStyle}" Margin="8,0,0,0" Padding="16,14">
        <StackPanel>
          <TextBlock Text="今日执行次数" FontSize="12" Foreground="#718096"/>
          <TextBlock x:Name="TxtTodayRuns" Text="0" FontSize="28" FontWeight="Bold"
                     Foreground="#3182CE" Margin="0,4,0,0"/>
        </StackPanel>
      </Border>
    </Grid>

    <!-- 任务列表 -->
    <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 列表头工具栏 -->
        <Border Grid.Row="0" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="16,12">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="任务列表" FontSize="14" FontWeight="SemiBold" Foreground="#2D3748"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
              <TextBlock Text="仅显示启用:" Foreground="#718096" FontSize="12"
                         VerticalAlignment="Center" Margin="0,0,6,0"/>
              <CheckBox x:Name="ChkActiveOnly" VerticalAlignment="Center"
                        Checked="ChkActiveOnly_Changed" Unchecked="ChkActiveOnly_Changed"/>
            </StackPanel>
          </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="1" x:Name="TaskGrid" Style="{StaticResource ModernDataGrid}"
                  ItemsSource="{Binding TaskItems}" AutoGenerateColumns="False"
                  SelectionChanged="TaskGrid_SelectionChanged">
          <DataGrid.Columns>
            <DataGridTextColumn Header="ID" Binding="{Binding Task.Id}" Width="50" IsReadOnly="True"/>
            <DataGridTextColumn Header="任务名称" Binding="{Binding Task.TaskName}" Width="160" IsReadOnly="True"/>
            <DataGridTextColumn Header="数据调用配置" Binding="{Binding DataCallName}" Width="160" IsReadOnly="True"/>
            <DataGridTextColumn Header="触发方式" Binding="{Binding Task.TriggerTypeDisplay}" Width="80" IsReadOnly="True"/>
            <DataGridTextColumn Header="触发参数" Binding="{Binding TriggerParam}" Width="140" IsReadOnly="True"/>
            <DataGridTemplateColumn Header="状态" Width="90">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <Border CornerRadius="10" Padding="10,3" HorizontalAlignment="Center"
                          Background="{Binding StatusBrush}">
                    <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="11" FontWeight="Medium"/>
                  </Border>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="上次运行" Binding="{Binding Task.LastRunTime, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                Width="150" IsReadOnly="True"/>
            <DataGridTextColumn Header="下次运行" Binding="{Binding NextFireDisplay}" Width="150" IsReadOnly="True"/>
            <DataGridTemplateColumn Header="操作" Width="260">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="4,0">
                    <Button Content="▶ 立即执行" Tag="{Binding Task.Id}" FontSize="11"
                            Style="{StaticResource PrimaryButton}" Padding="8,4" Margin="0,0,4,0"
                            Click="BtnRunNow_Click"
                            Visibility="{Binding RunButtonVisibility}"/>
                    <Button Content="⏹ 停止" Tag="{Binding Task.Id}" FontSize="11"
                            Style="{StaticResource DangerButton}" Padding="8,4" Margin="0,0,4,0"
                            Click="BtnStopTask_Click"
                            Visibility="{Binding StopButtonVisibility}"/>
                    <Button Content="启用" Tag="{Binding Task.Id}" FontSize="11"
                            Style="{StaticResource PrimaryButton}" Padding="8,4" Margin="0,0,4,0"
                            Click="BtnEnable_Click"
                            Visibility="{Binding EnableButtonVisibility}"/>
                    <Button Content="禁用" Tag="{Binding Task.Id}" FontSize="11"
                            Style="{StaticResource DangerButton}" Padding="8,4" Margin="0,0,4,0"
                            Click="BtnDisable_Click"
                            Visibility="{Binding DisableButtonVisibility}"/>
                    <Button Content="查看日志" Tag="{Binding Task.Id}" FontSize="11"
                            Style="{StaticResource SecondaryButton}" Padding="8,4"
                            Click="BtnViewLog_Click"/>
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
      </Grid>
    </Border>

    <!-- 分隔 -->
    <Grid Grid.Row="3" Height="12"/>

    <!-- 进度监控面板 -->
    <Border Grid.Row="4" Style="{StaticResource CardStyle}" Padding="0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="16,10">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="执行进度监控" FontSize="14" FontWeight="SemiBold"
                       Foreground="#2D3748" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
              <TextBlock x:Name="TxtProgressTaskName" Text="无正在运行的任务"
                         Foreground="#718096" FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0"/>
              <Button Content="清除" Style="{StaticResource SecondaryButton}"
                      Padding="10,4" FontSize="12" Click="BtnClearProgress_Click"/>
            </StackPanel>
          </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
          </Grid.ColumnDefinitions>

          <!-- 左: 进度条 + 日志滚动 -->
          <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!-- 进度条区 -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <ProgressBar x:Name="PbProgress" Height="14" Minimum="0" Maximum="100" Value="0"
                           Background="#EDF2F7" Foreground="#3182CE"/>
              <TextBlock x:Name="TxtProgressPct" Grid.Column="1" Text="0%" Margin="10,0,0,0"
                         FontSize="13" FontWeight="Medium" Foreground="#3182CE" VerticalAlignment="Center"/>
            </Grid>
            <!-- 实时日志 -->
            <Border Grid.Row="1" Background="#F7FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4">
              <ScrollViewer x:Name="SvProgressLog" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="TxtProgressLog" Margin="10,8" FontFamily="Consolas" FontSize="12"
                           Foreground="#4A5568" TextWrapping="Wrap" LineHeight="20"/>
              </ScrollViewer>
            </Border>
          </Grid>

          <!-- 右: 数字统计 -->
          <Grid Grid.Column="1">
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#EBF8FF" CornerRadius="6" Margin="0,0,0,6" Padding="12,8">
              <StackPanel>
                <TextBlock Text="总记录数" FontSize="11" Foreground="#2C5282"/>
                <TextBlock x:Name="TxtTotal" Text="—" FontSize="20" FontWeight="Bold" Foreground="#2C5282"/>
              </StackPanel>
            </Border>
            <Border Grid.Row="1" Background="#F0FFF4" CornerRadius="6" Margin="0,0,0,6" Padding="12,8">
              <StackPanel>
                <TextBlock Text="成功处理" FontSize="11" Foreground="#276749"/>
                <TextBlock x:Name="TxtSuccess" Text="—" FontSize="20" FontWeight="Bold" Foreground="#276749"/>
              </StackPanel>
            </Border>
            <Border Grid.Row="2" Background="#FFF5F5" CornerRadius="6" Margin="0,0,0,6" Padding="12,8">
              <StackPanel>
                <TextBlock Text="处理失败" FontSize="11" Foreground="#9B2C2C"/>
                <TextBlock x:Name="TxtFailed" Text="—" FontSize="20" FontWeight="Bold" Foreground="#9B2C2C"/>
              </StackPanel>
            </Border>
            <Border Grid.Row="3" Background="#FFFAF0" CornerRadius="6" Padding="12,8">
              <StackPanel>
                <TextBlock Text="耗时" FontSize="11" Foreground="#7B341E"/>
                <TextBlock x:Name="TxtElapsed" Text="—" FontSize="20" FontWeight="Bold" Foreground="#7B341E"/>
              </StackPanel>
            </Border>
          </Grid>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Page>
